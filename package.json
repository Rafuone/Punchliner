{
  "name": "punchline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c magenta,cyan \"npm -w server run dev\" \"npm -w client run dev\"",
    "build": "npm -w client run build",
    "start": "node server/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
